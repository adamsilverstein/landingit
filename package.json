{
  "name": "landingit",
  "version": "1.0.0",
  "description": "LandinGit — the keyboard-first GitHub PR dashboard",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "landingit": "./bin/landingit.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "electron:dev": "ELECTRON=1 npm run build && electron .",
    "electron:build": "ELECTRON=1 npm run build && electron-builder --mac",
    "prepublishOnly": "npm run build"
  },
  "build": {
    "appId": "com.github.adamsilverstein.landingit",
    "productName": "LandinGit",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "keywords": [
    "github",
    "dashboard",
    "pull-requests",
    "pr",
    "code-review"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adamsilverstein/landingit.git"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "@tanstack/react-virtual": "^3.13.23",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.1"
  }
}
